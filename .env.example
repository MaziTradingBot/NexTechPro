# Copy this file to ".env" and fill in your values.

# Postgres connection string from Neon, Supabase, or Vercel Postgres.
# Example (Neon): postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Secret used to sign admin login sessions. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"

# Optional: the first general admin created by `npm run seed`.
ADMIN_EMAIL="admin@nextechpro.ua"
ADMIN_PASSWORD="admin12345"
